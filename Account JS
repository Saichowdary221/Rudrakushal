function restrictContactAccess(executionContext) {
    var formContext = executionContext.getFormContext();
    var restrictedRole = "MDU - Membership MSA";

    // Check if the current user has the restricted role
    var roles = Xrm.Utility.getGlobalContext().userSettings.roles;
    var hasRestrictedRole = false;
    roles.forEach(function (role) {
        if (role.name === restrictedRole) {
            hasRestrictedRole = true;
        }
    });

    // Only proceed with the API check if the user has the restricted role
    if (!hasRestrictedRole) return;

    // Get the contact ID from the form
    var contactId = formContext.data.entity.getId().replace(/[{}]/g, "");

    // Build the API request URL
    var clientUrl = Xrm.Utility.getGlobalContext().getClientUrl();
    var apiUrl = clientUrl +
        "/api/data/v9.2/contacts(" + contactId + ")" +
        "?$expand=mdu_role_contact_contact($select=mdu_roleid,mdu_securitylevel)";

    var req = new XMLHttpRequest();
    req.open("GET", apiUrl, true);
    req.setRequestHeader("OData-MaxVersion", "4.0");
    req.setRequestHeader("OData-Version", "4.0");
    req.setRequestHeader("Content-Type", "application/json; charset=utf-8");
    req.setRequestHeader("Accept", "application/json");
    req.setRequestHeader("Prefer", "odata.include-annotations=*");

    req.onreadystatechange = function () {
        if (this.readyState === 4) {
            req.onreadystatechange = null;

            if (this.status === 200) {
                var result = JSON.parse(this.response);
                console.log(result);

                var isRestricted = false;

                // Loop through the related mdu_role_contact_contact records
                for (var j = 0; j < result.mdu_role_contact_contact.length; j++) {
                    var mdu_roleid = result.mdu_role_contact_contact[j]["mdu_roleid"];
                    var mdu_securitylevel = result.mdu_role_contact_contact[j]["mdu_securitylevel"];
                    var mdu_securitylevel_formatted = result.mdu_role_contact_contact[j]["mdu_securitylevel@OData.Community.Display.V1.FormattedValue"];

