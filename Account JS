function getContactdetails(primaryControl) {

    var formContext = primaryControl;

    // Get current Account Id
    var accountId = formContext.data.entity.getId();

    if (!accountId) {
        Xrm.Navigation.openAlertDialog({
            text: "Please save the record first."
        });
        return;
    }

    // Remove curly braces
    accountId = accountId.replace("{", "").replace("}", "");

    var query = "?$select=fullname,emailaddress1&$filter=_parentcustomerid_value eq " + accountId;

    Xrm.WebApi.retrieveMultipleRecords("contact", query).then(
        function success(result) {

            if (result.entities.length === 0) {
                Xrm.Navigation.openAlertDialog({
                    text: "No related contacts found."
                });
                return;
            }

            var message = "Related Contacts:\n\n";

            result.entities.forEach(function (contact) {
                message += "Name: " + (contact.fullname || "N/A") +
                           " | Email: " + (contact.emailaddress1 || "N/A") + "\n";
            });

            Xrm.Navigation.openAlertDialog({ text: message });

        },
        function (error) {
            Xrm.Navigation.openErrorDialog({ message: error.message });
        }
    );
}

