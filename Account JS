async function reassignQuotes(duplicateId, masterId) {

    var query =
        "?$select=quoteid,statecode,statuscode" +
        "&$filter=_customerid_value eq '" + duplicateId + "'";

    var result = await parent.Xrm.WebApi.retrieveMultipleRecords("quote", query);

    for (let quote of result.entities) {

        var quoteId = quote.quoteid;
        var originalState = quote.statecode;
        var originalStatus = quote.statuscode;

        if (originalState === 2 || originalState === 3) {

            await parent.Xrm.WebApi.updateRecord("quote", quoteId, {
                statecode: 0,
                statuscode: 1
            });
        }

        await parent.Xrm.WebApi.updateRecord("quote", quoteId, {
            "customerid@odata.bind": "/contacts(" + masterId + ")"
        });

        //won
        if (originalState === 2) {

            await parent.Xrm.WebApi.updateRecord("quote", quoteId, {
                statecode: 2,
                statuscode: originalStatus
            });
     
        } else if (originalState === 3) {

            //closed
            await parent.Xrm.WebApi.updateRecord("quote", quoteId, {
                statecode: 3,
                statuscode: originalStatus
            });
        }
    }
}

