function NavigateCustomPageBulkEditButtonSubGrid(selectedControl, launchContext) {
    
    if (!selectedControl || typeof selectedControl.getSelectedRows !== "function") {
        Xrm.Navigation.openAlertDialog({
            text: "Bulk Edit: Subgrid context not available.",
            title: "Error"
        });
        console.error("Bulk Edit: selectedControl is not a valid subgrid.");
        return;
    }

    var selectedRows = selectedControl.getSelectedRows();

    if (!selectedRows || selectedRows.getLength() === 0) {
        Xrm.Navigation.openAlertDialog({
            text: "Please select at least one record to bulk edit.",
            title: "No Records Selected"
        });
        return;
    }

    var engagementIds = [];
    selectedRows.forEach(function (row) {
        try {
            var id = row.getData().getEntity().getId();
            if (id) {
                engagementIds.push(id.replace(/[{}]/g, "").toLowerCase());
            }
        } catch (e) {
            console.warn("Bulk Edit: Failed to get ID from row", e);
        }
    });

    if (engagementIds.length === 0) {
        Xrm.Navigation.openAlertDialog({
            text: "Could not retrieve IDs from the selected records.",
            title: "Error"
        });
        return;
    }

    var pageInput = {
        pageType: "custom",
        name: "mcs_bulkedit_dcd17",
        parameters: {
            SelectedEngagementIds: engagementIds.join(","),
            LaunchContext: launchContext || "subgrid"
        }
    };

    var navigationOptions = {
        target: 2,
        width: { value: 90, unit: "%" },
        height: { value: 80, unit: "%" }
    };

    Xrm.Navigation.navigateTo(pageInput, navigationOptions)
        .then(function () {
            
            try {
                selectedControl.refresh();
            } catch (e) {
                console.warn("Bulk Edit: Subgrid refresh failed.", e);
            }
        })
        .catch(function (error) {
            console.error("Bulk Edit navigation failed:", error);
            Xrm.Navigation.openAlertDialog({
                text: "Navigation to Bulk Edit page failed: " + (error.message || error),
                title: "Navigation Error"
            });
        });
}

